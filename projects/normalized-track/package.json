{
  "name": "render-normalized-track",
  "version": "0.2.1",
  "description": "Ableton Live extension for rendering a normalized copy of an audio track.",
  "author": "portalsurfer",
  "type": "module",
  "main": "dist/extension.js",
  "engines": {
    "node": ">=24.14.1"
  },
  "scripts": {
    "build": "tsc --noEmit && tsx build.ts --production",
    "build:dev": "tsc --noEmit && tsx build.ts",
    "start": "npm run build:dev && extensions-cli run",
    "package": "node scripts/package.mjs"
  },
  "dependencies": {
    "@ableton-extensions/sdk": "file:../../sdk/ableton-extensions-sdk-1.0.0-beta.0.tgz",
    "audio-decode": "^2.2.3"
  },
  "devDependencies": {
    "@ableton-extensions/cli": "file:../../sdk/ableton-extensions-cli-1.0.0-beta.0.tgz",
    "@types/node": "^24.1.0",
    "esbuild": "0.28.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3"
  }
}
